{
  "kind": "collectionType",
  "collectionName": "gallery_items",
  "info": {
    "singularName": "gallery-item",
    "pluralName": "gallery-items",
    "displayName": "Gallery Item",
    "description": "Galería fotográfica y de video de FESAPADE"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "imagen": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "videos"]
    },
    "categoria": {
      "type": "enumeration",
      "enum": ["foto", "video"],
      "default": "foto"
    }
  }
}
