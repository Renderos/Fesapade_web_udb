# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ── Secrets (generate each with: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))") ──
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=
JWT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Production (Railway PostgreSQL) — replace the SQLite vars above with these:
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local: http://localhost:3000
# Production: https://your-app.vercel.app,https://fesapade.org.sv
CORS_ORIGIN=http://localhost:3000

# ── Cloudinary (media uploads — production only) ──────────────────────────────
# Create a free account at https://cloudinary.com
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
